generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  isFirm              Boolean   @default(false)
  name                String
  slug                String    @unique
  email               String?
  phone               String?
  bio                 String?
  photoUrl            String?
  city                String?
  state               String?
  zipCode             String?
  latitude            Float?
  longitude           Float?
  practiceAreas       String?
  notableResults      String?
  keyCharacteristics  String?
  barNumber           String?
  websiteUrl          String?
  linkedin            String?
  facebook            String?
  approved            Boolean   @default(false)
}