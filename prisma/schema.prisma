generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Guide {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  slug        String   @unique
  excerpt     String?
  body        String
  categories    String[] @default([])
  coverImageUrl String?
  authorName    String?
  authorSlug  String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
}

model Listing {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  isFirm              Boolean   @default(false)
  isNonprofit         Boolean   @default(false)
  name                String
  slug                String    @unique
  email               String?
  phone               String?
  photoUrl            String?
  firm                String?
  tagline             String?
  description         String?
  streetAddress       String?
  city                String?
  state               String?
  zipCode             String?
  isNational          Boolean  @default(false)
  latitude            Float?
  longitude           Float?
  specialties         String[]  @default([])
  notableResults      String[]  @default([])
  keyCharacteristics  String[]  @default([])
  barNumber           String?
  website             String?
  linkedin            String?
  facebook            String?
  approved            Boolean   @default(false)
  featured            Boolean   @default(false)
}