generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  isFirm              Boolean   @default(false)
  name                String
  slug                String    @unique
  email               String?
  phone               String?
  bio                 String?
  photoUrl            String?
  firm                String?
  tagline             String?
  description         String?
  city                String?
  state               String?
  zipCode             String?
  isNational          Boolean  @default(false)
  latitude            Float?
  longitude           Float?
  specialties         String[]  @default([])
  notableResults      String[]  @default([])
  keyCharacteristics  String[]  @default([])
  barNumber           String?
  websiteUrl          String?
  linkedin            String?
  facebook            String?
  approved            Boolean   @default(false)
  featured            Boolean   @default(false)
}